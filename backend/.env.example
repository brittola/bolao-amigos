# Servidor
PORT=3001
NODE_ENV=development

# Banco de dados (Postgres via docker-compose)
DATABASE_URL=postgres://bolao:bolao@localhost:5432/bolao
TEST_DATABASE_URL=postgres://bolao:bolao@localhost:5432/bolao_test

# Auth
JWT_SECRET=troque-este-segredo
JWT_EXPIRES_IN=7d

# Cron
# ENABLE_CRON=true  -> roda node-cron interno (use em hosts always-on, ex. Fly.io / local)
# ENABLE_CRON=false -> desligado; agende via cron externo nos endpoints /cron/* (ex. Render)
ENABLE_CRON=true
CRON_SECRET=troque-este-segredo-de-cron

# Admin (criado pelo seed)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@bolao.local
ADMIN_PASSWORD=troque-esta-senha

# Provider de dados de jogos/resultados: 'api-football' ou 'football-data'
FOOTBALL_PROVIDER=api-football

# API-Football
API_FOOTBALL_KEY=sua-chave-aqui
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# Liga usada para filtrar os jogos (1 = World Cup). A busca é por DATA, sem season,
# por causa da restrição do plano free; filtramos pela league.id no código.
API_FOOTBALL_LEAGUE=1
API_FOOTBALL_SEASON=2026   # mantido para referência; NÃO é enviado na busca (plano free)
# Teto de segurança de requests por dia (free = 100)
API_FOOTBALL_DAILY_CAP=90

# football-data.org (alternativa grátis: 10 req/min, inclui a Copa do Mundo = WC).
# Token grátis em https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=seu-token-aqui
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITION=WC
